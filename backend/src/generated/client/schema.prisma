// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AttendanceRecord {
  id           Int    @id @default(autoincrement())
  date         String // YYYY-MM-DD format
  eventType    String // e.g., "Entry", "Exit", "Break Start", "Break End"
  timestamp    String // Exact time, could be ISO or simple HH:mm
  employeeName String // Name of the scraped employee

  createdAt DateTime @default(now())

  @@unique([employeeName, date, eventType, timestamp])
}

model Settings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Employee {
  id         Int      @id @default(autoincrement())
  employeeId String?  @unique
  firstName  String
  lastName   String
  department String?
  position   String?
  email      String?  @unique
  createdAt  DateTime @default(now())
}

model Shift {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  startTime     String // format "HH:mm"
  endTime       String // format "HH:mm"
  isOvernight   Boolean  @default(false)
  maxBreakMins  Int      @default(30)
  toleranceMins Int      @default(15)
  color         String   @default("#3b82f6") // fallback badge color
  createdAt     DateTime @default(now())
}

model OvertimeApproval {
  id           Int      @id @default(autoincrement())
  employeeName String
  date         String // YYYY-MM-DD
  approved     Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([employeeName, date])
}

model LeaveRecord {
  id           Int      @id @default(autoincrement())
  employeeName String
  date         String // "YYYY-MM-DD"
  leaveType    String // "odmor", "bolovanje", "slobodan_dan"
  note         String?
  createdAt    DateTime @default(now())

  @@unique([employeeName, date])
}
