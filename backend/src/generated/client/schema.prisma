// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AttendanceRecord {
  id           Int    @id @default(autoincrement())
  date         String // YYYY-MM-DD format
  eventType    String // e.g., "Entry", "Exit", "Break Start", "Break End"
  timestamp    String // Exact time, could be ISO or simple HH:mm
  employeeName String // Name of the scraped employee

  createdAt DateTime @default(now())

  @@unique([employeeName, date, eventType, timestamp])
}

model Settings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Employee {
  id         Int      @id @default(autoincrement())
  employeeId String?  @unique
  firstName  String
  lastName   String
  department String?
  position   String?
  email      String?  @unique
  createdAt  DateTime @default(now())
}
